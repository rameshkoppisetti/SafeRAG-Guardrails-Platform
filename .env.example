APP_NAME=SafeRAG Guardrails Platform
APP_ENV=local
AWS_REGION=us-east-1
USE_BEDROCK=false
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
VECTOR_BACKEND=memory
VECTOR_TOP_K=5
CHUNK_SIZE=900
CHUNK_OVERLAP=120
PGVECTOR_CONNECTION=postgresql+psycopg://langchain:langchain@localhost:6024/langchain
PGVECTOR_COLLECTION=safe_rag_documents

# session memory storage
SESSION_BACKEND=postgres
POSTGRES_CONNECTION=postgresql://langchain:langchain@localhost:6024/langchain
PINECONE_API_KEY=
PINECONE_INDEX_NAME=safe-rag-documents
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=1024
